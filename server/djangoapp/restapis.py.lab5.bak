import requests
import os
from urllib.parse import urlencode

backend_url = os.getenv("backend_url", "http://localhost:3030")
sentiment_analyzer_url = os.getenv("sentiment_analyzer_url", "http://localhost:5050/")


def get_request(endpoint, **kwargs):
    params = ""
    if kwargs:
        params = "?" + urlencode(kwargs)

    request_url = backend_url + endpoint + params
    print("GET from", request_url)

    try:
        response = requests.get(request_url)
        return response.json()
    except Exception as e:
        print("GET request failed:", e)
        return []


def post_request(endpoint, data):
    request_url = backend_url + endpoint
    print("POST to", request_url)

    try:
        response = requests.post(request_url, json=data)
        return response.json()
    except Exception as e:
        print("POST request failed:", e)
        return {"error": str(e)}


def analyze_review_sentiments(text):
    request_url = sentiment_analyzer_url + "analyze/" + text

    try:
        response = requests.get(request_url)
        return response.json()
    except Exception as e:
        print("Sentiment analyzer failed:", e)
        return {"sentiment": "neutral"}
